[Script]
revenuecat = type=http-response, pattern=^https:\/\/api\.tatao\.net\/appapi\/\?service=User\.getBaseInfo&version_ios=25&token=[^&]+&uid=\d+$, script-path="", requires-body=true, max-size=-1, timeout=60

deleteHeader = type=http-request, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts|subscribers), script-path=https://raw.githubusercontent.com/hiyuuu2202/locket-gold/refs/heads/main/new.js, timeout=60

[MITM]

hostname = %APPEND% api.tatao.net
