[Script]
revenuecat = type=http-response, pattern=^https:\/\/api\.tatao\.net\/appapi\/\?service=User\.getBaseInfo&version_ios=25&token=[^&]+&uid=\d+$, script-path=https://raw.githubusercontent.com/hiyuuu2202/tatao-test/refs/heads/main/tatao.js, requires-body=true, max-size=-1, timeout=60

[MITM]

hostname = %APPEND% api.tatao.net
